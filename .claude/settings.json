{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(yarn install)",
      "Bash(yarn dev:*)",
      "Bash(yarn build)",
      "Bash(yarn preview)",
      "Bash(yarn lint)",
      "Bash(yarn format:*)",
      "Bash(node_modules/.bin/tsc:*)",
      "Bash(node_modules/.bin/biome:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)"
    ]
  }
}
